# Copy to .env.local (gitignored) for production-like builds against a deployed Worker.
# Cloudflare Pages: set the same name in Project → Settings → Environment variables.
#
# Example (no trailing slash):
# VITE_SI_WORKER_URL=https://api.optiview.ai
#
# Production demo (pnpm deploy:demo) loads si.js from the snippet CDN:
# VITE_SI_SNIPPET_ORIGIN=https://cdn.optiview.ai
# VITE_SI_DEMO_USE_HOSTED_SNIPPET=1
# VITE_SI_SNIPPET_VERSION=7ea5380  # demo-only: cache-bust query on hosted si.js (deploy sets from CDN version.json)
# VITE_SI_DEMO_SNIPPET_INSPECTOR=1
#
# Optional — links in "For webmasters / integration docs" (defaults shown):
# VITE_SI_LIVE_DEMO_URL=https://optiview.ai
# VITE_SI_DASHBOARD_URL=https://si-session-dashboard.pages.dev

VITE_SI_WORKER_URL=
