# Copy to .env.local (gitignored) for production-like builds against a deployed Worker.
# Cloudflare Pages: set the same name in Project → Settings → Environment variables.
#
# Example (no trailing slash):
# VITE_SI_WORKER_URL=https://session-intelligence-worker.your-subdomain.workers.dev
#
# Optional — "Live demo site" link in integration section:
# VITE_SI_LIVE_DEMO_URL=https://optiview.ai

VITE_SI_WORKER_URL=
