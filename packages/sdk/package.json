{
  "name": "@si/sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/sdk.js",
  "module": "./dist/sdk.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/sdk.js"
    },
    "./src": "./src/index.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@si/shared": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.3"
  }
}
