{
  "name": "session-intelligence",
  "version": "0.1.0",
  "private": true,
  "description": "Session Intelligence — anonymous, in-session personalization with measurable lift.",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm --filter @si/sdk build && pnpm --filter @si/demo-retailer build && pnpm --filter @si/dashboard build",
    "dev": "pnpm -r --parallel dev",
    "dev:demo": "pnpm --filter @si/demo-retailer dev",
    "dev:dashboard": "pnpm --filter @si/dashboard dev",
    "dev:sdk": "pnpm --filter @si/sdk dev",
    "dev:worker": "pnpm --filter @si/worker dev",
    "cloudflare:bootstrap": "node scripts/cloudflare-bootstrap.mjs",
    "cloudflare:up": "bash scripts/cloudflare-up.sh",
    "cloudflare:deploy:worker": "pnpm --filter @si/worker run deploy",
    "cloudflare:deploy:pages": "bash scripts/deploy-pages.sh",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs:generate": "node scripts/generate-session-intelligence-docs.mjs",
    "docs:copy-to-apps": "node scripts/copy-integration-docs.mjs"
  },
  "devDependencies": {
    "happy-dom": "^15.11.7",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "wrangler": "^3.114.0"
  },
  "engines": {
    "node": ">=20.10"
  }
}
