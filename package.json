{
  "name": "session-intelligence",
  "version": "0.1.0",
  "private": true,
  "description": "Session Intelligence — anonymous, in-session personalization with measurable lift.",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm --filter @si/sdk build && pnpm --filter @si/demo-retailer build && pnpm --filter @si/dashboard build",
    "build:snippet": "node scripts/build-snippet-cdn.mjs",
    "package:snippet": "node scripts/package-hosted-snippet.mjs",
    "build:marketing": "pnpm --filter @si/marketing-site build",
    "dev": "pnpm -r --parallel dev",
    "dev:demo": "pnpm --filter @si/demo-retailer dev",
    "dev:dashboard": "pnpm --filter @si/dashboard dev",
    "dev:marketing": "pnpm --filter @si/marketing-site dev",
    "dev:sdk": "pnpm --filter @si/sdk dev",
    "dev:worker": "pnpm --filter @si/worker dev",
    "cloudflare:bootstrap": "node scripts/cloudflare-bootstrap.mjs",
    "cloudflare:up": "bash scripts/cloudflare-up.sh",
    "cloudflare:deploy:worker": "pnpm --filter @si/worker run deploy",
    "cloudflare:deploy:pages": "bash scripts/deploy-pages.sh",
    "deploy:worker": "pnpm --filter @si/worker run deploy",
    "deploy:worker:development": "pnpm --filter @si/worker run deploy:development",
    "deploy:snippet": "bash scripts/deploy-snippet.sh",
    "deploy:demo": "bash scripts/deploy-demo-pages.sh",
    "deploy:dashboard": "bash scripts/deploy-dashboard-pages.sh",
    "deploy:marketing": "bash scripts/deploy-marketing-pages.sh",
    "deploy:all": "bash scripts/deploy-all.sh",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:decisions": "tsx scripts/run-decision-fixtures.ts",
    "decision-fixtures": "tsx scripts/run-decision-fixtures.ts",
    "docs:generate": "node scripts/generate-session-intelligence-docs.mjs",
    "docs:copy-to-apps": "node scripts/copy-integration-docs.mjs",
    "check:integrations": "node scripts/check-integration-examples.mjs",
    "bundle:session-intelligence-review": "bash scripts/build-session-intelligence-review-bundle.sh"
  },
  "devDependencies": {
    "happy-dom": "^15.11.7",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "wrangler": "^3.114.0"
  },
  "engines": {
    "node": ">=20.10"
  }
}
